# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env*.local

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# scripts de exploração local (não subir ao git)
scripts/explore-*.mjs
scripts/inspect-*.mjs
scripts/test-*.mjs

.vercel
.env*

# gravações e transcrições brutas de ligações — conteúdo sensível/estratégico,
# nunca deve ir para o repositório. Só o que é distilado manualmente para
# docs/wiki/business-decisions-log.md ou docs/TASKS.md é versionado.
/reunioes/audio/*
/reunioes/transcricoes/*
!/reunioes/audio/.gitkeep
!/reunioes/transcricoes/.gitkeep

# extratos brutos de sessões do Claude Code — só local, nunca versionar (contêm
# transcrições verbatim que já vazaram credenciais reais coladas em conversas
# antigas). O destilado vai para docs/wiki/.
/raw/

# superpowers scratch (progress ledgers, per-task briefs/reports)
.superpowers/
