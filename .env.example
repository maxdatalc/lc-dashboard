# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Criptografia (tokens SQL bridge e dados sensíveis no banco)
ENCRYPTION_KEY=

# Domínios — roteamento por subdomínio
# Em desenvolvimento, as vars abaixo são ignoradas (usa /admin e /dashboard por path)
NEXT_PUBLIC_APP_URL=https://app.lcgestor.com.br
NEXT_PUBLIC_ADMIN_URL=https://admpainel.lcgestor.com.br
ADMIN_DOMAIN=admpainel.lcgestor.com.br

# Bridge de testes oficial — usar sempre para validação de queries contra ERP real
# durante desenvolvimento (nunca hardcode a URL/token real aqui nem em nenhum arquivo
# versionado — só em .env.local, que é gitignored)
BRIDGE_TEST_URL=
BRIDGE_TEST_TOKEN=

# SQL Bridge — desenvolvimento local (aponta direto para SQL Server sem bridge)
# Defina MSSQL_HOST para ativar queryDev em vez de queryBridge
MSSQL_HOST=
MSSQL_PORT=1433
MSSQL_DATABASE=
MSSQL_USER=
MSSQL_PASSWORD=

# Asaas — pagamentos
# Sandbox: https://sandbox.asaas.com/api/v3 | Produção: https://www.asaas.com/api/v3
ASAAS_API_KEY=
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
# Token configurado no painel Asaas → Configurações → Webhooks → access_token
ASAAS_WEBHOOK_TOKEN=

# APIs internas (server-to-server) chamadas pelo lc-storefront
# Segredo compartilhado que autentica /api/internal/* (stock-check, frete-cotar).
# Precisa ser o MESMO valor configurado no .env.local do lc-storefront.
# Gerar um valor forte, ex.: openssl rand -hex 32
INTERNAL_API_SECRET=

# Melhor Envio — cotação de frete (fase 3 do lc-storefront)
# Sandbox: https://sandbox.melhorenvio.com.br | Produção: https://melhorenvio.com.br
MELHOR_ENVIO_TOKEN=
MELHOR_ENVIO_BASE_URL=https://sandbox.melhorenvio.com.br